# ─────────────────────────────────────────────
# SERPENT RAG PLATFORM — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── General ──────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=production
HTTP_PORT=80
HTTPS_PORT=443
ACME_EMAIL=admin@example.com

# ── Authentication ───────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── PostgreSQL ───────────────────────────────
POSTGRES_USER=serpent
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=serpent

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password

# ── Qdrant (Vector Store) ───────────────────
QDRANT_API_KEY=CHANGE_ME_generate_api_key

# ── Neo4j (Graph Store) ─────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_strong_password

# ── LLM Providers ───────────────────────────
# At least one is required
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY_HERE

# ── Optional: Local LLM ─────────────────────
# OLLAMA_BASE_URL=http://ollama:11434
# LOCAL_MODEL=llama3.1:70b

# ── Monitoring ───────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_strong_password

# ── Embedding Model ─────────────────────────
# Options: openai, local (sentence-transformers), fastembed
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3

# ── Security ────────────────────────────────
# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS
FRONTEND_URL=https://localhost
